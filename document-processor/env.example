# ============================================
# AWS Configuration
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=your-s3-bucket-name

# SQS Configuration
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name
# Optional: use separate queue for local dev (run scripts/create_local_queue.py first)
# SQS_QUEUE_URL_LOCAL=https://sqs.us-east-1.amazonaws.com/123456789012/pdf-processing-queue-local
# Optional: Dead Letter Queue for failed messages (after maxReceiveCount retries)
# SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-dlq-name

# ============================================
# LlamaCloud Configuration
# Get your API key from: https://cloud.llamaindex.ai/api-key
# ============================================
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# ============================================
# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=your-openai-api-key

# ============================================
# PostgreSQL Configuration
# For LangGraph checkpoints (Phase 5 HITL), ensure psycopg is installed:
#   pip install 'psycopg[binary]' psycopg-pool
# ============================================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=document_processor
POSTGRES_USER=docuser
POSTGRES_PASSWORD=docpass_dev_2026
DEBUG_SQL=false

# ============================================
# pgAdmin Configuration (Optional)
# Access pgAdmin at: http://localhost:5050
# ============================================
PGADMIN_DEFAULT_EMAIL=admin@docprocessor.local
PGADMIN_DEFAULT_PASSWORD=docpass_dev_2026

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Application Configuration
# ============================================
STORAGE_PATH=./storage/uploads
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=100

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# ============================================
# Task Configuration
# ============================================
TASK_RESULT_TTL=3600

# ============================================
# AVAE: External API Keys (for verification)
# ============================================
# Companies House: https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=

# HM Land Registry: https://use-land-registry-data.service.gov.uk/
# LAND_REGISTRY_API_KEY=

# EPC Open Data: https://epc.opendatacommunities.org/
# EPC_API_KEY=

# SEC EDGAR (Financial vertical): No API key required. User-Agent is set in sec_edgar.py.
